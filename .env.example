# Clerk
# Use publishable and secret keys from the same Clerk application/environment.
# If Clerk reports token-not-active-yet locally, sync the system clock.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Convex
# Run `npm run convex:sync` after changing files in convex/.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Code execution
# Optional fallback. Defaults to the public Judge0 CE endpoint in development.
JUDGE0_API_URL=
# Optional. Preferred provider for supported languages when configured.
ONLINECOMPILER_API_KEY=
ONLINECOMPILER_API_URL=https://api.onlinecompiler.io
# Optional. Enables faster browser-to-OnlineCompiler WebSocket execution.
# Create this from OnlineCompiler's Widgets page, not API Keys.
NEXT_PUBLIC_ONLINECOMPILER_WS_KEY=

# Lemon Squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET=
